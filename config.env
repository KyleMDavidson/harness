#!/usr/bin/env bash
# config.env — Central configuration for the Firecracker agentic harness.
# Sourced by all scripts. Any value can be overridden by setting the variable
# in the environment before running a script, e.g.:
#   VM_MEM_MB=1024 sudo ./setup_vm.sh start

# ---------------------------------------------------------------------------
# Firecracker binary & runtime
# ---------------------------------------------------------------------------
FC_BINARY="${FC_BINARY:-firecracker}"
FC_SOCKET="${FC_SOCKET:-/tmp/firecracker.socket}"
FC_PID_FILE="${FC_PID_FILE:-/tmp/firecracker.pid}"
FC_LOG_FILE="${FC_LOG_FILE:-/tmp/fc-logs/firecracker-boot.log}"

# ---------------------------------------------------------------------------
# VM resources
# ---------------------------------------------------------------------------
VM_VCPUS="${VM_VCPUS:-2}"
VM_MEM_MB="${VM_MEM_MB:-512}"

# ---------------------------------------------------------------------------
# Artifacts  (ARTIFACTS_DIR is set by each script before sourcing this file)
# ---------------------------------------------------------------------------
KERNEL_IMAGE="${KERNEL_IMAGE:-${ARTIFACTS_DIR}/vmlinux}"
ROOTFS_IMAGE="${ROOTFS_IMAGE:-${ARTIFACTS_DIR}/rootfs.ext4}"
ROOTFS_SIZE_MB="${ROOTFS_SIZE_MB:-2048}"    # MiB; build-time only
ALPINE_VERSION="${ALPINE_VERSION:-3.19}"    # build-time only

# ---------------------------------------------------------------------------
# Network
# NOTE: VM_IP, BRIDGE_IP, VM_GATEWAY, and VM_NETMASK are baked into the
# rootfs at build time (rootfs_build.sh). Changing them after the image is
# built requires a reset_rootfs.sh run.
# ---------------------------------------------------------------------------
BRIDGE="${BRIDGE:-fcbr0}"
TAP="${TAP:-fctap0}"
BRIDGE_IP="${BRIDGE_IP:-172.16.0.1}"
VM_IP="${VM_IP:-172.16.0.2}"
VM_NETMASK="${VM_NETMASK:-255.255.255.0}"
VM_GATEWAY="${VM_GATEWAY:-${BRIDGE_IP}}"    # gateway seen by the guest
VM_MAC="${VM_MAC:-AA:FC:00:00:00:01}"
HOST_IFACE="${HOST_IFACE:-$(ip route get 8.8.8.8 2>/dev/null | awk '{for(i=1;i<=NF;i++) if($i=="dev") print $(i+1)}' | head -1)}"

# ---------------------------------------------------------------------------
# Guest / agent
# NOTE: AGENT_PORT and VM_HOSTNAME are baked into the rootfs at build time.
# ---------------------------------------------------------------------------
VM_HOSTNAME="${VM_HOSTNAME:-fc-agent}"
AGENT_PORT="${AGENT_PORT:-8080}"
